# ============================================================
# LawAskLLM production environment example
# Copy to .env only on the server and fill real secrets.
# Do not commit real values.
# ============================================================

# LLM (OpenAI-compatible)
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=deepseek-v3.2

# DashScope Embedding
DASHSCOPE_API_KEY=your_dashscope_api_key

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=law_llm

# JWT
JWT_SECRET_KEY=replace_with_a_long_random_string
APP_ENV=production
ENABLE_DEFAULT_ADMIN_INIT=0
DEFAULT_ADMIN_PASSWORD=

# Optional: vector DB directory override
# LAWASK_VECTOR_DB_DIR=/home/ubuntu/law-chroma-data

# Optional retrieval params
RETRIEVAL_TOP_K=6
RETRIEVAL_USE_MMR=false
RETRIEVAL_MMR_FETCH_K=24
RETRIEVAL_MMR_LAMBDA=0.55

# Optional CORS as JSON array for backend/app/core/config.py
# ALLOWED_ORIGINS=["http://your-domain.com","https://your-domain.com"]
