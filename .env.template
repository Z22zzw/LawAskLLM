# ============================================================
# 法律 LLM 平台 — 环境变量模板
# 复制此文件为 .env 并填入真实值
# ============================================================

# ── LLM（OpenAI 兼容接口）──
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=deepseek-v3.2

# ── DashScope Embedding ──
DASHSCOPE_API_KEY=your_dashscope_api_key

# ── MySQL ──
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=law_llm

# ── JWT（生产环境请替换为随机长字符串）──
JWT_SECRET_KEY=请替换为安全的随机字符串

# ── Chroma 向量库目录（可选）──
# 默认：项目根下「向量数据库」。若遇 SQLite readonly database（权限/Docker UID），改为当前用户可写的绝对路径，例如：
# LAWASK_VECTOR_DB_DIR=/home/ubuntu/law-chroma-data

# ── 检索参数（可选）──
RETRIEVAL_TOP_K=6
RETRIEVAL_USE_MMR=false
RETRIEVAL_MMR_FETCH_K=24
RETRIEVAL_MMR_LAMBDA=0.55

# ── 后端 CORS（可选；不设则用 backend/app/core/config.py 默认列表）──
# Pydantic Settings 需 JSON 数组，例如：
# ALLOWED_ORIGINS=["http://49.235.100.186","https://yourdomain.com"]
